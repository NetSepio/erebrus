# Erebrus Node v2 — environment template
# Copy to /etc/erebrus/config.env (or .env for dev). Never commit real values.

# ── app ──────────────────────────────────────────────
RUNTYPE=release          # debug | release

# Runtime mode (v2.1): private | gateway — NOT the same as docker/host install UX
EREBRUS_MODE=private
# Deployment network profile: bridge | host-network | native (experimental)
EREBRUS_NETWORK_PROFILE=bridge

SERVER=0.0.0.0           # management API bind; API_BIND_ADDR overrides SERVER
# API_BIND_ADDR=127.0.0.1
# UNSAFE_PUBLIC_API=true # acknowledge public API exposure when bind is 0.0.0.0
HTTP_PORT=9080
NODE_NAME=
REGION=

# ── identity (the node's only secret) ────────────────
# BIP39 mnemonic — wallet key, libp2p PeerID and DID all derive from this
MNEMONIC=

# ── gateway ──────────────────────────────────────────
GATEWAY_URL=https://gateway.erebrus.io
# libp2p bootstrap multiaddr of the gateway (DHT advertise only)
GATEWAY_PEER_MULTIADDR=
# Wallet chain for node registration challenge (sol | evm)
WALLET_CHAIN=sol
# Persisted after first registration; can be set manually to skip auto-register
NODE_ID=
NODE_TOKEN=
# Public URL the gateway uses for PUT /api/v2/peers (defaults to http://WG_ENDPOINT_HOST:HTTP_PORT)
API_PUBLIC_URL=
GATEWAY_AUTO_REGISTER=true

# ── node API auth ────────────────────────────────────
# Bearer token guarding /api/v2 peer endpoints. Leave blank to auto-generate
# (the installer does this for you and prints it).
NODE_API_TOKEN=

# ── wireguard ────────────────────────────────────────
WG_CONF_DIR=/etc/wireguard
WG_INTERFACE_NAME=wg0
WG_ENDPOINT_HOST=        # public IP or DNS name clients connect to
WG_ENDPOINT_PORT=51820   # alias: WG_PORT
WG_IPv4_SUBNET=10.0.0.1/16
WG_DNS=1.1.1.1           # replaced by node-internal DNS when app hosting is on
WG_POST_UP=iptables -A FORWARD -i %i -j ACCEPT; iptables -A FORWARD -o %i -j ACCEPT; iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
WG_POST_DOWN=iptables -D FORWARD -i %i -j ACCEPT; iptables -D FORWARD -o %i -j ACCEPT; iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE

# ── stealth carriers (sing-box) ──────────────────────
# DPI-resistant fallbacks for when WireGuard UDP is blocked.
ENABLE_STEALTH=true
STEALTH_TCP_PORT=8443        # VLESS + REALITY (tcp); production gateway: 443
STEALTH_UDP_PORT=4443        # Hysteria2 / QUIC (udp); production gateway: 443
VLESS_PORT=8443              # legacy alias for STEALTH_TCP_PORT
HYSTERIA2_PORT=4443        # legacy alias for STEALTH_UDP_PORT
# comma-separated camouflage SNIs for REALITY (host:443 reachable from node)
REALITY_SERVER_NAMES=www.microsoft.com
# optional override of the host:port the REALITY handshake is proxied to
REALITY_HANDSHAKE_SERVER=
HYSTERIA2_OBFS_PASSWORD=     # empty = no salamander obfuscation
ENABLE_TUIC=false

# ── node-local state ─────────────────────────────────
STATE_DIR=/var/lib/erebrus   # erebrus.db (SQLite) lives here

# ── gateway mode / public edge (Phase 3+, opt-in) ────
PUBLIC_DOMAIN=               # e.g. apps.node.example.com
WILDCARD_DOMAIN=             # e.g. *.apps.node.example.com

# ── app hosting (legacy flag; maps to gateway public edge) ─
ENABLE_APP_HOSTING=false
APP_WILDCARD_DOMAIN=         # e.g. *.node-sg-1.erebrus.network

# ── registrar (on-chain, mocked in v2.0) ─────────────
CHAIN_REGISTRATION=off       # off | solana (future)
